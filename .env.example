# Copy this file to .env and fill in the values.
#   cp .env.example .env
# Generate the two secrets below with:
#   npm run gen-keys      (or: openssl rand -base64 32  for each)

# SQLite database file location.
#   Local dev:  file:./data/app.db
#   Docker:     file:/data/app.db   (set in docker-compose.yml; survives restarts via volume)
DATABASE_URL="file:./data/app.db"

# 32-byte base64 key for AES-256-GCM. Encrypts the Mistral API key at rest.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY="<32-byte base64 — run: openssl rand -base64 32>"

# Auth.js secret used to sign session cookies.
# Generate with: openssl rand -base64 32
AUTH_SECRET="<32-byte base64 — run: openssl rand -base64 32>"

# Public base URL of the app.
NEXTAUTH_URL="http://localhost:3000"

# Directory where uploaded audio files are stored.
#   Local dev:  ./data/uploads
#   Docker:     /data/uploads
UPLOAD_DIR="./data/uploads"

# Registration policy: "true" allows public signup; set "false" for single-operator mode
# (hides /register and rejects the register API). Flip to false after creating your account.
ALLOW_REGISTRATION="true"
